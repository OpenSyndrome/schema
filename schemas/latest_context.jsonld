{
  "@context": {
    "@version": 1.1,

    "osd": "https://w3id.org/opensyndrome/core/",
    "schema": "https://schema.org/",
    "dc": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "mondo": { "@id": "http://purl.obolibrary.org/obo/MONDO_", "@prefix": true },
    "iao":   { "@id": "http://purl.obolibrary.org/obo/IAO_",   "@prefix": true },
    "hpo":   { "@id": "http://purl.obolibrary.org/obo/HP_",    "@prefix": true },
    "doid":  { "@id": "http://purl.obolibrary.org/obo/DOID_",  "@prefix": true },

    "id": "@id",
    "type": "@type",

    "title": "schema:name",
    "description": "schema:description",
    "version": "schema:version",
    "language": "schema:inLanguage",
    "location": "schema:spatialCoverage",
    "organization": "schema:sourceOrganization",

    "authors": { "@id": "schema:author", "@container": "@set" },
    "published_at": { "@id": "schema:datePublished", "@type": "xsd:dateTime" },
    "published_by": { "@id": "schema:publisher", "@container": "@set" },
    "published_in": "schema:isPartOf",
    "keywords": { "@id": "schema:keywords", "@container": "@set" },
    "status": "schema:creativeWorkStatus",
    "human_readable_definition": "iao:0000115",
    "notes": { "@id": "schema:comment", "@container": "@set" },
    "same_as": "schema:sameAs",

    "references": { "@id": "dc:references", "@container": "@set" },
    "citation": "dc:bibliographicCitation",
    "url": {
      "@id": "schema:url",
      "@type": "@id"
    },
    "name": "schema:name",

    "scope": "osd:scope",
    "category": "osd:category",
    "open_syndrome_version": "osd:openSyndromeVersion",
    "definition_type": "osd:definitionType",
    "target_public_health_threats": { "@id": "osd:targetPublicHealthThreats", "@container": "@set" },

    "inclusion_criteria": { "@id": "osd:inclusionCriteria", "@container": "@set" },
    "exclusion_criteria": { "@id": "osd:exclusionCriteria", "@container": "@set" },

    "logical_operator": "osd:logicalOperator",
    "logical_operator_arguments": { "@id": "osd:logicalOperatorArguments", "@container": "@list" },
    "values": { "@id": "osd:values", "@container": "@set" },

    "code": {
      "@id": "osd:codeableConcept",
      "@context": {
        "code": "osd:codeValue",
        "system": "osd:codingSystem",
        "display": "schema:name"
      }
    },
    "system": "osd:codingSystem",
    "ontology_id": { "@id": "osd:ontologyId", "@type": "@id" },
    "attribute": "osd:attribute",
    "value": "osd:value",
    "operator": "osd:comparisonOperator",
    "display": "schema:name",
    "regex_pattern": "osd:regexPattern",
    "regex_flags": "osd:regexFlags",

    "criterion": "osd:Criterion",
    "syndrome": "osd:Syndrome",
    "symptom": "osd:Symptom",
    "diagnosis": "osd:Diagnosis",
    "diagnostic_test": "osd:DiagnosticTest",
    "professional_judgment": "osd:ProfessionalJudgment",
    "epidemiological_history": "osd:EpidemiologicalHistory",
    "demographic_criteria": "osd:DemographicCriteria"
  }
}
